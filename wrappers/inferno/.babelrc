{
  "compact": false,
  "presets": [
    [
      "@babel/preset-env",
      {
        // Build modern output for environments that support ES modules / classes.
        // This avoids transpiling native classes to ES5 which can cause a
        // "Cannot call a class constructor Component without |new|" error
        // when the runtime provides native classes (Inferno) but the wrapper
        // output was compiled to ES5-style constructors.
        "targets": {
          "esmodules": true
        }
      }
    ],
    ["@babel/typescript", {"isTSX": true, "allExtensions": true}]
  ],
  "plugins": [
    ["babel-plugin-inferno", { "imports": true }],
    ["@babel/plugin-proposal-class-properties"],
    ["@babel/plugin-transform-private-methods"],
    ["@babel/plugin-transform-private-property-in-object"]
  ]
}
