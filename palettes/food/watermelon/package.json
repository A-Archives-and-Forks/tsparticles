{
  "name": "@tsparticles/palette-watermelon",
  "version": "4.0.0-beta.12",
  "description": "tsParticles watermelon palette",
  "homepage": "https://particles.js.org",
  "scripts": {
    "build": "tsparticles-cli build",
    "build:ci": "tsparticles-cli build --ci",
    "version": "tsparticles-cli build -d && git add package.dist.json",
    "prepack": "pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tsparticles/tsparticles.git",
    "directory": "palettes/food/watermelon"
  },
  "publishConfig": {
    "directory": "dist",
    "linkDirectory": true,
    "access": "public"
  },
  "author": "Matteo Bruni <matteo.bruni@me.com>",
  "license": "MIT",
  "sideEffects": false,
  "browser": "dist/browser/index.js",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "browser": "./dist/browser/index.js",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "umd": "./dist/umd/index.js",
      "default": "./dist/cjs/index.js"
    },
    "./package.json": "./dist/package.json",
    "./lazy": {
      "types": "./dist/types/index.lazy.d.ts",
      "browser": "./dist/browser/index.lazy.js",
      "import": "./dist/esm/index.lazy.js",
      "require": "./dist/cjs/index.lazy.js",
      "umd": "./dist/umd/index.lazy.js",
      "default": "./dist/cjs/index.lazy.js"
    }
  },
  "prettier": "@tsparticles/prettier-config",
  "dependencies": {
    "@tsparticles/engine": "workspace:*"
  },
  "type": "module"
}
