{
  "name": "@tsparticles/confetti-website",
  "version": "4.0.0-beta.12",
  "description": "tsParticles confetti webpage",
  "private": true,
  "type": "module",
  "main": "public/index.html",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "handlebars confetti-modes.handlebars -f public/js/confetti-modes.js -k isCustom",
    "build:ci": "handlebars confetti-modes.handlebars -f public/js/confetti-modes.js -k isCustom",
    "deploy": "rimraf node_modules/.cache && node deploy.js",
    "lint": "eslint public/js",
    "lint:fix": "eslint public/js --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tsparticles/tsparticles.git",
    "directory": "websites/confetti"
  },
  "author": "Matteo Bruni <matteo.bruni@me.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/tsparticles/tsparticles/issues"
  },
  "homepage": "https://confetti.js.org",
  "dependencies": {
    "tsparticles": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "gh-pages": "^6.3.0",
    "globals": "^17.4.0",
    "handlebars": "^4.7.9",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3"
  }
}
