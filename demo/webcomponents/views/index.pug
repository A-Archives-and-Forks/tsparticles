doctype html
html(lang="en")
    head
        meta(charset="utf-8")
        meta(name="description" content= "tsParticles")
        meta(name="author" content= "Matteo Bruni")
        meta(name="apple-mobile-web-app-capable" content="yes")
        meta(name="viewport" content="width=device-width, initial-scale=1.0, minimum-scale=1.0, maximum-scale=1.0, user-scalable=no")

        meta(name="twitter:card" content="summary_large_image")
        meta(name="twitter:creator" content="@HollowMatt_ITA")
        meta(name="twitter:image:src" content="https://particles.js.org/images/demo2.png")
        meta(property="og:title" content="tsParticles - A lightweight TypeScript library for creating particles")
        meta(property="og:site_name" content="tsParticles")
        meta(property="og:url" content="https://particles.js.org/")
        meta(property="og:description" content="A lightweight TypeScript library for creating particles.")
        meta(property="og:image" content="https://particles.js.org/images/demo2.png")

        title tsParticles

        link(href="/stylesheets/main.css" rel="stylesheet" type="text/css")

    body
        // Load engine & polyfills first, then initialize the webcomponents engine
        script(src="/tsparticles/tsparticles.bundle.min.js")
        // Load webcomponents polyfills from a CDN so the demo does not require
        // a local installation of @webcomponents/webcomponentsjs. The
        // custom-elements ES5 adapter is needed because the wrapper is
        // transpiled to ES5 and relies on the adapter when run in older
        // environments or when classes are downleveled.
        script(src="https://unpkg.com/@webcomponents/webcomponentsjs@2.6.0/custom-elements-es5-adapter.js")
        script(src="https://unpkg.com/@webcomponents/webcomponentsjs@2.6.0/webcomponents-loader.js")

        // Import the webcomponents module only after the engine script is
        // loaded. Using the engine script's load event is more reliable
        // than aggressive polling and avoids races across browsers.
        script(type="module").
            (async () => {
                const createDebugPanel = () => {
                    const panel = document.createElement('div');
                    panel.id = 'wc-debug';
                    panel.style.position = 'fixed';
                    panel.style.left = '10px';
                    panel.style.top = '10px';
                    panel.style.zIndex = '99999';
                    panel.style.padding = '8px';
                    panel.style.background = 'rgba(255,255,255,0.95)';
                    panel.style.color = '#000';
                    panel.style.fontFamily = 'monospace';
                    panel.style.fontSize = '12px';
                    panel.style.maxWidth = '360px';
                    panel.style.maxHeight = '70vh';
                    panel.style.overflow = 'auto';
                    panel.innerHTML = '<strong>WebComponents Demo Debug</strong><br/>';

                    const log = document.createElement('pre');
                    log.id = 'wc-debug-log';
                    log.style.margin = '4px 0 0 0';
                    log.style.whiteSpace = 'pre-wrap';
                    log.style.fontFamily = 'monospace';
                    log.style.fontSize = '12px';
                    panel.appendChild(log);

                    document.body.appendChild(panel);

                    const update = (msg) => {
                        const time = new Date().toISOString().slice(11,23);
                        log.textContent = `${time} ${msg}\n` + log.textContent;
                    };

                    return update;
                };

                const debug = createDebugPanel();

                const engineSrc = '/tsparticles/tsparticles.bundle.min.js';

                const waitForEngineScript = (timeout = 5000) => new Promise((resolve) => {
                    if (globalThis.tsParticles) {
                        resolve(true);
                        return;
                    }

                    let script = document.querySelector(`script[src="${engineSrc}"]`);

                    if (!script) {
                        // Ideally the page already includes the script; if not,
                        // create it so we control the onload.
                        script = document.createElement('script');
                        script.src = engineSrc;
                        document.head.appendChild(script);
                    }

                    const onLoad = () => {
                        cleanup();
                        resolve(!!globalThis.tsParticles);
                    };

                    const onError = () => {
                        cleanup();
                        resolve(false);
                    };

                    const cleanup = () => {
                        script.removeEventListener('load', onLoad);
                        script.removeEventListener('error', onError);
                    };

                    script.addEventListener('load', onLoad);
                    script.addEventListener('error', onError);

                    // Fallback: poll for globalThis.tsParticles in case the
                    // bundle initializes the global before the load event.
                    const start = Date.now();
                    const poll = setInterval(() => {
                        if (globalThis.tsParticles) {
                            clearInterval(poll);
                            cleanup();
                            resolve(true);
                        } else if (Date.now() - start > timeout) {
                            clearInterval(poll);
                            cleanup();
                            resolve(false);
                        }
                    }, 100);
                });

                // Capture global errors/unhandled promise rejections to the demo
                // debug panel so we can see full stack & reason information.
                window.addEventListener('unhandledrejection', (evt) => {
                    try {
                        const reason = evt.reason;
                        const msg = reason && reason.message ? reason.message : String(reason);
                        debug('unhandledrejection: ' + msg);
                    } catch (e) {
                        debug('unhandledrejection: <unable to stringify reason>');
                    }
                    // Also print to console for developer tools
                    // eslint-disable-next-line no-console
                    console.error('Unhandled rejection captured by demo', evt.reason);
                });

                window.addEventListener('error', (evt) => {
                    try {
                        debug('window.error: ' + (evt?.message ?? String(evt)));
                    } catch (e) {
                        debug('window.error');
                    }
                });

                debug('module start');
                debug('globalThis.tsParticles before wait: ' + (!!globalThis.tsParticles));

                const engineReady = await waitForEngineScript(5000);
                debug('engineReady: ' + engineReady + ' global:' + !!globalThis.tsParticles);

                // Wait for the WebComponents polyfills (if any) to finish
                // loading before importing/defining the ES5-transpiled wrapper.
                const waitForWebComponents = (timeout = 2000) => new Promise((resolve) => {
                    try {
                        // If the loader exposes a WebComponents global and it's not
                        // ready yet, wait for the event. Otherwise resolve
                        // immediately.
                        if (window.WebComponents && !window.WebComponents.ready) {
                            const onReady = () => {
                                window.removeEventListener('WebComponentsReady', onReady);
                                resolve(true);
                            };

                            window.addEventListener('WebComponentsReady', onReady);

                            // Fallback timeout in case the event never fires.
                            setTimeout(() => {
                                window.removeEventListener('WebComponentsReady', onReady);
                                resolve(true);
                            }, timeout);
                        } else {
                            resolve(true);
                        }
                    } catch (e) {
                        resolve(true);
                    }
                });

                debug('waiting for WebComponents polyfills (if present)');
                await waitForWebComponents(2000);

                try {
                    const mod = await import('/@tsparticles/webcomponents/web-particles.js');

                    if (mod?.initParticlesEngine) {
                        await mod.initParticlesEngine(async (e) => {
                          await loadFull(e);
                        });

                        debug('initParticlesEngine: OK');
                    } else {
                        debug('initParticlesEngine export not found in module');
                    }

                    // If the module exposes a helper to define the custom
                    // element, invoke it after polyfills are loaded. This
                    // avoids the "Constructor requires 'new' operator" issue
                    // when classes are transpiled to ES5 and the
                    // custom-elements-es5-adapter is required.
                    try {
                        if (typeof mod.defineParticlesElement === 'function') {
                            mod.defineParticlesElement();
                            debug('defineParticlesElement: OK');
                        }
                    } catch (e) {
                        debug('defineParticlesElement failed: ' + (e?.message ?? e));
                    }
                } catch (err) {
                    debug('initParticlesEngine: ERROR - ' + (err?.message ?? err));
                    // eslint-disable-next-line no-console
                    console.error(err);
                }

                // Create the element after initialization and attach a couple
                // of debug listeners so it's easier to diagnose why nothing
                // appears in the demo (no-op in production).
                try {
                    const el = document.createElement('web-particles');
                    el.id = 'tsparticles';
                    el.setAttribute('url', '/presets/default.json');

                    el.addEventListener('particlesLoaded', (e) => {
                        debug('particlesLoaded event received');

                        try {
                            const c = e?.detail;
                            if (c) {
                                const size = c.canvas?.size;
                                debug('container: width=' + (size?.width ?? 'n/a') + ' height=' + (size?.height ?? 'n/a'));
                            }
                        } catch (err) {
                            debug('particlesLoaded handler error: ' + (err?.message ?? err));
                        }

                        // Inspect canvases present in the document to help diagnose
                        // invisible rendering (zero size, hidden display, wrong z-index, etc.)
                        try {
                            const canvases = Array.from(document.querySelectorAll('canvas'));

                            if (canvases.length === 0) {
                                debug('no <canvas> elements found in document');
                            } else {
                                canvases.forEach((cv, idx) => {
                                    try {
                                        const rect = cv.getBoundingClientRect();
                                        const cs = getComputedStyle(cv);
                                        const info = {
                                            index: idx,
                                            widthAttr: cv.width,
                                            heightAttr: cv.height,
                                            offsetW: cv.offsetWidth,
                                            offsetH: cv.offsetHeight,
                                            clientW: cv.clientWidth,
                                            clientH: cv.clientHeight,
                                            rectW: rect.width,
                                            rectH: rect.height,
                                            display: cs.display,
                                            visibility: cs.visibility,
                                            opacity: cs.opacity,
                                            position: cs.position,
                                            zIndex: cs.zIndex,
                                            top: cs.top,
                                            left: cs.left,
                                            background: cs.backgroundColor,
                                        };

                                        debug('canvas[' + idx + ']: ' + JSON.stringify(info));
                                    } catch (innerErr) {
                                        debug('canvas inspect error: ' + (innerErr?.message ?? innerErr));
                                    }
                                });
                            }
                        } catch (err) {
                            debug('canvas listing error: ' + (err?.message ?? err));
                        }

                        // Additional engine-level diagnostics when container is missing
                        try {
                            const engine = globalThis.tsParticles;
                            debug('tsParticles present: ' + !!engine);
                            debug('tsParticles.load type: ' + (engine ? typeof engine.load : 'n/a'));
                            debug('tsParticles.items length: ' + (engine?.items?.length ?? 'n/a'));

                            if (!e?.detail) {
                                debug('particlesLoaded detail is null — dumping engine item ids');
                                try {
                                    const ids = (engine?.items ?? []).map((c) => (c?.id?.description ?? c?.id ?? null));
                                    debug('engine.items ids: ' + JSON.stringify(ids));
                                } catch (dumpErr) {
                                    debug('engine.items dump error: ' + (dumpErr?.message ?? dumpErr));
                                }
                            }
                        } catch (err) {
                            debug('particlesLoaded engine debug error: ' + (err?.message ?? err));
                        }

                        // eslint-disable-next-line no-console
                        console.log('web-particles: particlesLoaded', e?.detail);

                        // Demo-only: if the container exists but isn't animating, try to start it.
                        // This helps diagnose situations where a valid container is created but
                        // the animation loop didn't start (e.g. unexpected autoPlay=false or
                        // initialization races). We avoid changing library code and only attempt
                        // a safe start from the demo page.
                        try {
                            const container = e?.detail;

                            if (container) {
                                try {
                                    debug('container.animationStatus: ' + !!container.animationStatus);
                                    debug('container.actualOptions.autoPlay: ' + (container.actualOptions?.autoPlay ?? 'n/a'));
                                } catch (dErr) {
                                    debug('container diagnostic read failed: ' + (dErr?.message ?? dErr));
                                }

                                if (!container.animationStatus && typeof container.play === 'function') {
                                    debug('container not animating; attempting to call container.play()');

                                    try {
                                        container.play();
                                    } catch (playErr) {
                                        debug('container.play() threw: ' + (playErr?.message ?? playErr));
                                    }

                                    // If still not animating after a short delay, attempt a demo-only
                                    // fallback: set autoPlay to true and call play() again. This
                                    // respects consumer code by only running from the demo.
                                    setTimeout(() => {
                                        try {
                                            debug('post-play: animationStatus=' + !!container.animationStatus);

                                            if (!container.animationStatus) {
                                                debug('forcing container.actualOptions.autoPlay = true and calling play() (demo fallback)');

                                                try {
                                                    if (container.actualOptions) {
                                                        container.actualOptions.autoPlay = true;
                                                    }

                                                    container.play();
                                                } catch (forceErr) {
                                                    debug('force play failed: ' + (forceErr?.message ?? forceErr));
                                                }

                                                debug('after force: animationStatus=' + !!container.animationStatus);
                                            }
                                        } catch (postErr) {
                                            debug('post-play diagnostics failed: ' + (postErr?.message ?? postErr));
                                        }
                                    }, 50);
                                }

                                // Additional deep diagnostics: check for internal flags that
                                // may indicate why the animation loop is not running. These
                                // are non-public and may not exist on some engine builds, so
                                // we guard accesses with try/catch.
                                try {
                                    // Some builds keep internals under varying names. Probe
                                    // a few likely fields for useful signals.
                                    const internals = {
                                        _paused: container._paused,
                                        _firstStart: container._firstStart,
                                        _drawAnimationFrame: container._drawAnimationFrame,
                                        _delayTimeout: container._delayTimeout,
                                    };

                                    debug('container internals: ' + JSON.stringify(internals));
                                } catch (iErr) {
                                    debug('container internals read failed: ' + (iErr?.message ?? iErr));
                                }
                            }
                        } catch (autoplayErr) {
                            debug('autoplay check error: ' + (autoplayErr?.message ?? autoplayErr));
                        }
                    });

                    el.addEventListener('particlesError', (e) => {
                        try {
                            const d = e?.detail;
                            const msg = d?.diagnostic?.message ?? d?.original?.message ?? String(d);
                            debug('particlesError: ' + msg);

                            if (d?.diagnostic) {
                                try {
                                    debug('diagnostic: ' + JSON.stringify(d.diagnostic));
                                } catch (jsonErr) {
                                    debug('diagnostic: <unstringifiable>');
                                }
                            }

                            if (d?.original?.stack) {
                                debug('stack: ' + d.original.stack);
                            }
                        } catch (handlerErr) {
                            debug('particlesError handler failed: ' + (handlerErr?.message ?? handlerErr));
                        }

                        // Also mirror to the console for full DevTools inspection
                        // eslint-disable-next-line no-console
                        console.error('web-particles particlesError', e?.detail);
                    });

                    el.addEventListener('error', (e) => {
                        try {
                            const detail = e?.detail;
                            if (detail) {
                                debug('web-particles error event detail: ' + JSON.stringify(detail));
                            } else {
                                debug('web-particles error event: ' + (e?.message ?? String(e)));
                            }
                        } catch (err) {
                            debug('web-particles error event');
                        }

                        // eslint-disable-next-line no-console
                        console.error('web-particles error event', e);
                    });

                    debug('appending <web-particles> element');
                    document.body.appendChild(el);
                } catch (err) {
                    debug('error creating/appending element: ' + (err?.message ?? err));
                    // eslint-disable-next-line no-console
                    console.error(err);
                }
            })();
